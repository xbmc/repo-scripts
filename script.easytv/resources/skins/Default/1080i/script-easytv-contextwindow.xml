<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Context Menu Window
    Resolution: 1080i (1920x1080)

    Control IDs:
        100 - Button group list
        110 - Toggle Multiselect
        120 - Play Selection
        130 - Play From Here
        140 - Export Selection
        150 - Toggle Watched
        170 - Update Library
        180 - Refresh
-->
<window>
    <zorder>100000</zorder>
    <defaultcontrol always="true">100</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="99000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Context Menu Container -->
        <control type="group">
            <left>770</left>
            <top>300</top>
            <width>380</width>
            <height>480</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>384</width>
                <height>484</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Menu Background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>380</width>
                <height>480</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Menu Buttons -->
            <control type="grouplist" id="100">
                <left>20</left>
                <top>25</top>
                <width>340</width>
                <height>430</height>
                <itemgap>12</itemgap>
                <orientation>vertical</orientation>
                <onleft>100</onleft>
                <onright>100</onright>
                <onup>100</onup>
                <ondown>100</ondown>

                <!-- Toggle Multiselect -->
                <control type="button" id="110">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Play Selection -->
                <control type="button" id="120">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Play From Here -->
                <control type="button" id="130">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Export Selection -->
                <control type="button" id="140">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Toggle Watched -->
                <control type="button" id="150">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Update Library -->
                <control type="button" id="170">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Refresh -->
                <control type="button" id="180">
                    <width>340</width>
                    <height>50</height>
                    <align>left</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>25</textoffsetx>
                    <textcolor>ffFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.Accent)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
