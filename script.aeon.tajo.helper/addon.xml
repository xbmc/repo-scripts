<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.aeon.tajo.helper" name="Aeon Tajo Helper" version="1.0.4" provider-name="manfeed, sualfred">
    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.python.pluginsource" library="plugin.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Aeon Tajo Helper Script</summary>
        <description lang="en_GB">Helper script to provide features and functions to the Aeon Tajo skin. Based on script.embuary.helper from sualfred.</description>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <source>https://github.com/manfeed/script.aeon.tajo.helper</source>
        <news>v1.0.4 - Security hardening: explicit allowlists for action and info dispatch, defensive None handling in set_library_tags.</news>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
