<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Show Selector Dialog
    Resolution: 1080i (1920x1080)

    Control IDs:
        1   - Heading label
        2   - Search edit control
        5   - Clear search button
        10  - Enable All button
        11  - Ignore All button
        100 - Show list
        20  - Cancel button
        21  - Save button
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">2</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 1200x700 centered -->
        <control type="group">
            <left>360</left>
            <top>190</top>
            <width>1200</width>
            <height>700</height>
            <!-- Dialog open/close animations -->
            <animation type="WindowOpen" reversible="false">
                <effect type="zoom" start="92" end="100" center="auto" time="200" tween="back" easing="out" />
                <effect type="fade" start="0" end="100" time="150" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" time="150" tween="cubic" easing="in" />
                <effect type="fade" start="100" end="0" time="150" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>1204</width>
                <height>704</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1200</width>
                <height>700</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>1140</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>1140</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Search edit control (ID 2) + Clear button (ID 5) -->
            <control type="edit" id="2">
                <left>30</left>
                <top>82</top>
                <width>650</width>
                <height>40</height>
                <align>left</align>
                <aligny>center</aligny>
                <font>font12</font>
                <textoffsetx>15</textoffsetx>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <label> </label>
                <hinttext>Search shows...</hinttext>
                <onright>5</onright>
                <ondown>10</ondown>
                <onup>21</onup>
                <texturefocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturefocus>
                <texturenofocus border="12" colordiffuse="0fFFFFFF">common/white_rounded.png</texturenofocus>
            </control>
            <control type="button" id="5">
                <left>690</left>
                <top>82</top>
                <width>45</width>
                <height>40</height>
                <align>center</align>
                <aligny>center</aligny>
                <font>font12</font>
                <label>X</label>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                <onleft>2</onleft>
                <ondown>10</ondown>
                <onup>21</onup>
                <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
            </control>

            <!-- Enable All / Ignore All buttons -->
            <control type="group">
                <left>30</left>
                <top>132</top>
                <width>700</width>
                <height>40</height>

                <!-- Enable All Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>40</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font10</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <onup>2</onup>
                    <ondown>100</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Ignore All Button (ID 11) -->
                <control type="button" id="11">
                    <left>220</left>
                    <top>0</top>
                    <width>200</width>
                    <height>40</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font10</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <onup>2</onup>
                    <ondown>100</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>

            <!-- Show list (ID 100) -->
            <control type="list" id="100">
                <left>30</left>
                <top>182</top>
                <width>700</width>
                <height>440</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>100</onleft>
                <onright>20</onright>
                <onup>10</onup>
                <ondown>100</ondown>

                <!-- Unfocused item: name + checkmark -->
                <itemlayout width="700" height="50">
                    <!-- Show name -->
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>610</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <selectedcolor>$INFO[Window.Property(EasyTV.Accent)]</selectedcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Selected checkmark -->
                    <control type="image">
                        <left>650</left>
                        <top>10</top>
                        <width>30</width>
                        <height>30</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">check_on.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>

                    <!-- Unselected empty checkbox -->
                    <control type="image">
                        <left>650</left>
                        <top>10</top>
                        <width>30</width>
                        <height>30</height>
                        <texture colordiffuse="44FFFFFF">check_off.png</texture>
                        <visible>!ListItem.IsSelected</visible>
                    </control>
                </itemlayout>

                <!-- Focused item -->
                <focusedlayout width="700" height="50">
                    <!-- Accent background -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>700</width>
                        <height>50</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white.png</texture>
                    </control>

                    <!-- Show name -->
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>610</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                        <selectedcolor>$INFO[Window.Property(EasyTV.Accent)]</selectedcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Selected checkmark -->
                    <control type="image">
                        <left>650</left>
                        <top>10</top>
                        <width>30</width>
                        <height>30</height>
                        <texture>check_on.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>

                    <!-- Unselected empty checkbox -->
                    <control type="image">
                        <left>650</left>
                        <top>10</top>
                        <width>30</width>
                        <height>30</height>
                        <texture colordiffuse="66FFFFFF">check_off.png</texture>
                        <visible>!ListItem.IsSelected</visible>
                    </control>
                </focusedlayout>
            </control>

            <!-- Right panel: Poster for focused show -->
            <control type="group">
                <left>760</left>
                <top>182</top>
                <width>400</width>
                <height>440</height>

                <!-- Poster image from focused list item -->
                <control type="image">
                    <left>60</left>
                    <top>10</top>
                    <width>280</width>
                    <height>420</height>
                    <texture background="true">$INFO[Container(100).ListItem.Art(thumb)]</texture>
                    <aspectratio>keep</aspectratio>
                    <bordertexture border="2" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white.png</bordertexture>
                    <visible>!String.IsEmpty(Container(100).ListItem.Art(thumb))</visible>
                </control>
            </control>

            <!-- Cancel / Save buttons -->
            <control type="group">
                <left>740</left>
                <top>630</top>
                <width>430</width>
                <height>50</height>

                <!-- Cancel Button (ID 20) -->
                <control type="button" id="20">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>21</onright>
                    <onleft>100</onleft>
                    <onup>100</onup>
                    <ondown>2</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Save Button (ID 21) -->
                <control type="button" id="21">
                    <left>230</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>20</onright>
                    <onleft>100</onleft>
                    <onup>100</onup>
                    <ondown>2</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
