<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Select Dialog
    Resolution: 1080i (1920x1080)

    Multi-purpose selection dialog for wizard and settings.
    Supports single-select and multi-select (checkbox) modes.

    Window properties:
        EasyMovie.SingleSelect - "true" hides checkboxes and OK button

    ListItem properties:
        is_header - "true" marks non-selectable group header items
        checked   - "true" marks checked items (multi-select mode)

    Control IDs:
        1   - Heading label
        100 - Scrollable list
        10  - OK button (multi-select only)
        11  - Back button
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol>11</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 600x580 centered -->
        <control type="group">
            <left>660</left>
            <top>250</top>
            <width>600</width>
            <height>580</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>604</width>
                <height>584</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>600</width>
                <height>580</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>540</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>540</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Scrollable list (ID 100) -->
            <control type="list" id="100">
                <left>30</left>
                <top>82</top>
                <width>540</width>
                <height>420</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>100</onleft>
                <onright>10</onright>
                <onup>100</onup>
                <ondown>11</ondown>

                <!-- Unfocused item -->
                <itemlayout width="540" height="50">
                    <!-- === Header item: dimmed, centered label === -->
                    <control type="label">
                        <left>0</left>
                        <top>0</top>
                        <width>540</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>66FFFFFF</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>

                    <!-- === Normal item === -->
                    <!-- Checkbox: unchecked (multi-select only) -->
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="44FFFFFF">check_off.png</texture>
                        <visible>[!String.IsEqual(ListItem.Property(checked),true)] + !String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                    <!-- Checkbox: checked (multi-select only) -->
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">check_on.png</texture>
                        <visible>[String.IsEqual(ListItem.Property(checked),true)] + !String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>

                    <!-- Label: with checkbox offset (multi-select) -->
                    <control type="label">
                        <left>48</left>
                        <top>0</top>
                        <width>480</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                    <!-- Label: no offset (single-select) -->
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>510</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                </itemlayout>

                <!-- Focused item -->
                <focusedlayout width="540" height="50">
                    <!-- Accent background (hidden for headers) -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>540</width>
                        <height>50</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentBG)]">common/white.png</texture>
                        <visible>!String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>

                    <!-- === Header item: dimmed, centered label (no highlight) === -->
                    <control type="label">
                        <left>0</left>
                        <top>0</top>
                        <width>540</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>66FFFFFF</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>

                    <!-- === Normal item === -->
                    <!-- Checkbox: unchecked (multi-select only) -->
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="66FFFFFF">check_off.png</texture>
                        <visible>[!String.IsEqual(ListItem.Property(checked),true)] + !String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                    <!-- Checkbox: checked (multi-select only) -->
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">check_on.png</texture>
                        <visible>[String.IsEqual(ListItem.Property(checked),true)] + !String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>

                    <!-- Label: with checkbox offset (multi-select) -->
                    <control type="label">
                        <left>48</left>
                        <top>0</top>
                        <width>480</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                    <!-- Label: no offset (single-select) -->
                    <control type="label">
                        <left>15</left>
                        <top>0</top>
                        <width>510</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEqual(Window.Property(EasyMovie.SingleSelect),true) + !String.IsEqual(ListItem.Property(is_header),true)</visible>
                    </control>
                </focusedlayout>
            </control>

            <!-- Button Row: centered grouplist auto-positions visible buttons -->
            <control type="grouplist">
                <left>115</left>
                <top>515</top>
                <width>370</width>
                <height>50</height>
                <align>center</align>
                <itemgap>30</itemgap>
                <orientation>horizontal</orientation>
                <onup>100</onup>

                <!-- Back Button (ID 11) — always visible -->
                <control type="button" id="11">
                    <width>170</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <onup>100</onup>
                    <label>$ADDON[script.easymovie 32302]</label>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- OK Button (ID 10) — hidden in single-select -->
                <control type="button" id="10">
                    <width>170</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <onup>100</onup>
                    <visible>!String.IsEqual(Window.Property(EasyMovie.SingleSelect),true)</visible>
                    <label>$ADDON[script.easymovie 32300]</label>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
