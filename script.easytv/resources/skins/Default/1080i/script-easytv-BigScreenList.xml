<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Big Screen View
    Resolution: 1080i (1920x1080)

    Layout: Large fanart on left with reflection + Episode list on right

    Control IDs:
        655 - Main fixed list container
-->
<window>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Full screen background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="ff000000">common/white.png</texture>
        </control>

        <!-- Info bar at top -->
        <control type="label">
            <left>80</left>
            <top>30</top>
            <width>1760</width>
            <height>35</height>
            <font>font10</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>[COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(episodeno)][/COLOR]  •  $ADDON[script.easytv 32222]  [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(percentplayed)][/COLOR]  •  $ADDON[script.easytv 32223] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numondeck)][/COLOR]  •  $ADDON[script.easytv 32224] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numwatched)][/COLOR]  •  $ADDON[script.easytv 32225] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numskipped)][/COLOR]  •  $ADDON[script.easytv 32065] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(lastwatched)][/COLOR]  •  $INFO[Container(655).ListItem.Property(genre),[, ]]$INFO[Container(655).ListItem.Property(duration),  •  ~,/ep]</label>
        </control>

        <!-- Main content group -->
        <control type="group">
            <visible>Control.IsVisible(655)</visible>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- ==================== LEFT SIDE: FANART WITH REFLECTION ==================== -->
            <control type="group">
                <left>25</left>
                <top>75</top>
                <width>1200</width>
                <height>950</height>

                <!-- Main Fanart -->
                <control type="multiimage">
                    <left>35</left>
                    <top>8</top>
                    <width>1125</width>
                    <height>632</height>
                    <fadetime>250</fadetime>
                    <imagepath background="true">$INFO[Container(655).ListItem.Property(Fanart_Image)]</imagepath>
                    <aspectratio aligny="top">scale</aspectratio>
                </control>

                <!-- Reflected Fanart (flipped) -->
                <control type="multiimage">
                    <left>-33</left>
                    <top>585</top>
                    <width>1215</width>
                    <height>632</height>
                    <fadetime>250</fadetime>
                    <imagepath background="true" flipy="true">$INFO[Container(655).ListItem.Property(Fanart_Image)]</imagepath>
                    <aspectratio aligny="top">scale</aspectratio>
                    <animation effect="rotatex" start="85" end="85" time="0" center="668,0" condition="true">Conditional</animation>
                </control>

                <!-- Fade gradient over reflection -->
                <control type="image">
                    <left>-38</left>
                    <top>642</top>
                    <width>1800</width>
                    <height>450</height>
                    <texture>imagefade.png</texture>
                    <aspectratio aligny="top">scale</aspectratio>
                </control>
            </control>

            <!-- ==================== RIGHT SIDE: EPISODE LIST ==================== -->
            <control type="fixedlist" id="655">
                <left>1200</left>
                <top>80</top>
                <width>680</width>
                <height>920</height>
                <orientation>vertical</orientation>
                <focusposition>4</focusposition>
                <movement>1</movement>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>655</onleft>
                <onright>655</onright>
                <onup>655</onup>
                <ondown>655</ondown>
                <itemgap>8</itemgap>

                <!-- Unfocused list item -->
                <itemlayout width="680" height="55">
                    <!-- Background -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>660</width>
                        <height>45</height>
                        <texture colordiffuse="0cffffff">common/white.png</texture>
                    </control>

                    <!-- Show title only -->
                    <control type="label">
                        <left>15</left>
                        <top>12</top>
                        <width>610</width>
                        <height>30</height>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>630</left>
                        <top>17</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>
                </itemlayout>

                <!-- Focused list item -->
                <focusedlayout width="680" height="80">
                    <!-- Background (focused) -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>660</width>
                        <height>75</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white.png</texture>
                    </control>

                    <!-- Show title -->
                    <control type="label">
                        <left>15</left>
                        <top>10</top>
                        <width>630</width>
                        <height>30</height>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Episode title -->
                    <control type="label">
                        <left>15</left>
                        <top>40</top>
                        <width>610</width>
                        <height>26</height>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>$INFO[ListItem.Label2]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>630</left>
                        <top>28</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
