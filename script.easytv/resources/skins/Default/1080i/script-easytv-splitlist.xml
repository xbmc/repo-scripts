<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Split View (skin=3)
    Resolution: 1080i (1920x1080)
    Dialog-style: 1400x800 centered

    Two-column layout: compact show list on left, detail panel on right.

    Control IDs:
        655 - Main list container (left panel)
-->
<window>
    <zorder>1</zorder>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 1400x800 centered -->
        <control type="group">
            <left>260</left>
            <top>140</top>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>1404</width>
                <height>804</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1400</width>
                <height>800</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Content (visible when list is populated) -->
            <control type="group">
                <visible>Control.IsVisible(655)</visible>

                <!-- ==================== LEFT PANEL: SHOW LIST ==================== -->
                <control type="group">
                    <left>30</left>
                    <top>13</top>
                    <width>730</width>

                    <!-- Heading -->
                    <control type="label">
                        <left>0</left>
                        <top>0</top>
                        <width>730</width>
                        <height>40</height>
                        <font>font14_title</font>
                        <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                        <label>$INFO[Window.Property(EasyTV.AddonName)]</label>
                    </control>

                    <!-- Accent line separator -->
                    <control type="image">
                        <left>0</left>
                        <top>46</top>
                        <width>730</width>
                        <height>2</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
                    </control>
                </control>

                <!-- Show list -->
                <control type="list" id="655">
                    <left>30</left>
                    <top>71</top>
                    <width>730</width>
                    <height>700</height>
                    <orientation>vertical</orientation>
                    <scrolltime tween="sine" easing="out">200</scrolltime>
                    <onleft>655</onleft>
                    <onright>655</onright>
                    <onup>655</onup>
                    <ondown>655</ondown>

                    <!-- Unfocused row -->
                    <itemlayout width="730" height="50">
                        <!-- Show title -->
                        <control type="label">
                            <left>15</left>
                            <top>0</top>
                            <width>530</width>
                            <height>50</height>
                            <aligny>center</aligny>
                            <font>font12</font>
                            <textcolor>FFCCCCCC</textcolor>
                            <label>$INFO[ListItem.Label]</label>
                        </control>

                        <!-- Episode number -->
                        <control type="label">
                            <left>555</left>
                            <top>0</top>
                            <width>140</width>
                            <height>50</height>
                            <aligny>center</aligny>
                            <align>right</align>
                            <font>font10</font>
                            <textcolor>FF888888</textcolor>
                            <label>$INFO[ListItem.Property(episodeno)]</label>
                        </control>

                        <!-- Multiselect checkmark -->
                        <control type="image">
                            <left>705</left>
                            <top>13</top>
                            <width>24</width>
                            <height>24</height>
                            <texture>IconWatched.png</texture>
                            <visible>ListItem.IsSelected</visible>
                        </control>
                    </itemlayout>

                    <!-- Focused row -->
                    <focusedlayout width="730" height="50">
                        <!-- Accent background -->
                        <control type="image">
                            <left>0</left>
                            <top>0</top>
                            <width>730</width>
                            <height>50</height>
                            <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white.png</texture>
                        </control>

                        <!-- Show title -->
                        <control type="label">
                            <left>15</left>
                            <top>0</top>
                            <width>530</width>
                            <height>50</height>
                            <aligny>center</aligny>
                            <font>font12</font>
                            <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                            <label>$INFO[ListItem.Label]</label>
                        </control>

                        <!-- Episode number -->
                        <control type="label">
                            <left>555</left>
                            <top>0</top>
                            <width>140</width>
                            <height>50</height>
                            <aligny>center</aligny>
                            <align>right</align>
                            <font>font10</font>
                            <textcolor>ffFFFFFF</textcolor>
                            <label>$INFO[ListItem.Property(episodeno)]</label>
                        </control>

                        <!-- Multiselect checkmark -->
                        <control type="image">
                            <left>705</left>
                            <top>13</top>
                            <width>24</width>
                            <height>24</height>
                            <texture>IconWatched.png</texture>
                            <visible>ListItem.IsSelected</visible>
                        </control>
                    </focusedlayout>
                </control>

                <!-- ==================== RIGHT PANEL: DETAIL VIEW ==================== -->
                <control type="group">
                    <left>780</left>
                    <top>13</top>
                    <width>590</width>

                    <!-- Show poster (centered, 220x330) -->
                    <control type="image">
                        <left>185</left>
                        <top>20</top>
                        <width>220</width>
                        <height>330</height>
                        <texture background="true">$INFO[Container(655).ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>

                    <!-- Separator -->
                    <control type="image">
                        <left>0</left>
                        <top>365</top>
                        <width>590</width>
                        <height>2</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
                    </control>

                    <!-- Episode title -->
                    <control type="label">
                        <left>0</left>
                        <top>377</top>
                        <width>590</width>
                        <height>35</height>
                        <align>center</align>
                        <font>font13</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>$INFO[Container(655).ListItem.Label2]</label>
                    </control>

                    <!-- Genre + Duration -->
                    <control type="label">
                        <left>0</left>
                        <top>417</top>
                        <width>590</width>
                        <height>28</height>
                        <align>center</align>
                        <scroll>true</scroll>
                        <font>font10</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <label>$INFO[Container(655).ListItem.Property(genre),[, ]]$INFO[Container(655).ListItem.Property(duration),  •  ~,/ep]</label>
                    </control>

                    <!-- On Deck / Watched / Skipped counts -->
                    <control type="label">
                        <left>0</left>
                        <top>450</top>
                        <width>590</width>
                        <height>28</height>
                        <align>center</align>
                        <font>font10</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <label>$ADDON[script.easytv 32223] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numondeck)][/COLOR]  •  $ADDON[script.easytv 32224] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numwatched)][/COLOR]  •  $ADDON[script.easytv 32225] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numskipped)][/COLOR]</label>
                    </control>

                    <!-- Last watched + Progress -->
                    <control type="label">
                        <left>0</left>
                        <top>483</top>
                        <width>590</width>
                        <height>28</height>
                        <align>center</align>
                        <font>font10</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <label>$ADDON[script.easytv 32065]  [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(lastwatched)][/COLOR]  •  $ADDON[script.easytv 32222]  [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(percentplayed)][/COLOR]</label>
                    </control>

                    <!-- Separator -->
                    <control type="image">
                        <left>0</left>
                        <top>521</top>
                        <width>590</width>
                        <height>2</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
                    </control>

                    <!-- Plot -->
                    <control type="textbox">
                        <left>0</left>
                        <top>535</top>
                        <width>590</width>
                        <height>250</height>
                        <scroll>true</scroll>
                        <font>font10</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>[COLOR $INFO[Window.Property(EasyTV.Accent)]]$ADDON[script.easytv 32226]  [/COLOR]$INFO[Container(655).ListItem.Plot]</label>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>
