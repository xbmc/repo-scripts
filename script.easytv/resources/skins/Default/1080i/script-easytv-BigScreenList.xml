<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Big Screen View
    Resolution: 1080i (1920x1080)

    Layout: Large fanart on left with reflection + Episode list on right

    Control IDs:
        655 - Main fixed list container
-->
<window>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Full screen background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D1117">common/white.png</texture>
        </control>

        <!-- ==================== HEADER ==================== -->

        <!-- Addon name heading -->
        <control type="label">
            <left>80</left>
            <top>15</top>
            <width>800</width>
            <height>40</height>
            <font>font14_title</font>
            <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
            <label>$INFO[Window.Property(EasyTV.AddonName)]</label>
        </control>

        <!-- Item count -->
        <control type="label">
            <left>80</left>
            <top>20</top>
            <width>1760</width>
            <height>30</height>
            <align>right</align>
            <font>font10</font>
            <textcolor>FF888888</textcolor>
            <label>$INFO[Container(655).CurrentItem] / $INFO[Container(655).NumItems]</label>
        </control>

        <!-- Accent line separator -->
        <control type="image">
            <left>80</left>
            <top>60</top>
            <width>1760</width>
            <height>2</height>
            <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
        </control>

        <!-- Info bar (metadata for focused item) -->
        <control type="label">
            <left>80</left>
            <top>72</top>
            <width>1760</width>
            <height>25</height>
            <font>font10</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>$ADDON[script.easytv 32222]  [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(percentplayed)][/COLOR]  ·  $ADDON[script.easytv 32223] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numondeck)][/COLOR]  ·  $ADDON[script.easytv 32224] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numwatched)][/COLOR]  ·  $ADDON[script.easytv 32225] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numskipped)][/COLOR]  ·  $ADDON[script.easytv 32065] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(lastwatched)][/COLOR]</label>
        </control>

        <!-- Main content group -->
        <control type="group">
            <visible>Control.IsVisible(655)</visible>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- ==================== LEFT SIDE: FANART WITH REFLECTION ==================== -->
            <control type="group">
                <left>25</left>
                <top>105</top>
                <width>1200</width>
                <height>950</height>

                <!-- Main Fanart -->
                <control type="multiimage">
                    <left>35</left>
                    <top>8</top>
                    <width>1125</width>
                    <height>632</height>
                    <fadetime>250</fadetime>
                    <imagepath background="true">$INFO[Container(655).ListItem.Property(Fanart_Image)]</imagepath>
                    <aspectratio aligny="top">scale</aspectratio>
                </control>

                <!-- Show title below fanart -->
                <control type="label">
                    <left>35</left>
                    <top>650</top>
                    <width>1125</width>
                    <height>45</height>
                    <font>font13</font>
                    <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Label]</label>
                </control>

                <!-- Episode title -->
                <control type="label">
                    <left>35</left>
                    <top>700</top>
                    <width>1125</width>
                    <height>30</height>
                    <font>font12</font>
                    <textcolor>ffFFFFFF</textcolor>
                    <label>$INFO[Container(655).ListItem.Label2]</label>
                </control>

                <!-- Plot -->
                <control type="textbox">
                    <left>35</left>
                    <top>740</top>
                    <width>1125</width>
                    <height>160</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                </control>
            </control>

            <!-- ==================== RIGHT SIDE: EPISODE LIST ==================== -->
            <control type="fixedlist" id="655">
                <left>1200</left>
                <top>105</top>
                <width>680</width>
                <height>895</height>
                <orientation>vertical</orientation>
                <focusposition>4</focusposition>
                <movement>1</movement>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>655</onleft>
                <onright>655</onright>
                <onup>655</onup>
                <ondown>655</ondown>
                <itemgap>8</itemgap>

                <!-- Unfocused list item -->
                <itemlayout width="680" height="55">
                    <!-- Background -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>660</width>
                        <height>45</height>
                        <texture colordiffuse="0cffffff">common/white.png</texture>
                    </control>

                    <!-- Show title -->
                    <control type="label">
                        <left>15</left>
                        <top>12</top>
                        <width>610</width>
                        <height>30</height>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>630</left>
                        <top>17</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>
                </itemlayout>

                <!-- Focused list item -->
                <focusedlayout width="680" height="125">
                    <!-- Background (focused) -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>660</width>
                        <height>125</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white.png</texture>
                    </control>

                    <!-- Show poster -->
                    <control type="image">
                        <left>10</left>
                        <top>8</top>
                        <width>73</width>
                        <height>110</height>
                        <texture background="true">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>

                    <!-- Show title -->
                    <control type="label">
                        <left>95</left>
                        <top>10</top>
                        <width>530</width>
                        <height>30</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Episode title -->
                    <control type="label">
                        <left>95</left>
                        <top>42</top>
                        <width>530</width>
                        <height>25</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>[COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[ListItem.Property(episodeno)][/COLOR]  ·  $INFO[ListItem.Label2]</label>
                    </control>

                    <!-- Genre + Duration -->
                    <control type="label">
                        <left>95</left>
                        <top>73</top>
                        <width>530</width>
                        <height>22</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>$INFO[ListItem.Property(duration)]$INFO[ListItem.Genre,  ·  ]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>630</left>
                        <top>50</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
