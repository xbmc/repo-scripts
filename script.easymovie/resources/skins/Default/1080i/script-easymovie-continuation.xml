<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Continuation Prompt Dialog
    Resolution: 1080i (1920x1080)

    Shown when a movie set member finishes playing, offers to play
    the next movie in the set with a countdown timer.

    Control IDs:
        1  - Heading label
        2  - Message label (primary)
        3  - Timer label (countdown)
        4  - Subtitle label (secondary info)
        10 - Yes/primary button
        11 - No/secondary button
        20 - Movie poster image
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">10</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 800x480 centered -->
        <control type="group">
            <left>560</left>
            <top>300</top>
            <width>800</width>
            <height>490</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>804</width>
                <height>494</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>800</width>
                <height>490</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>740</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <font>font14_title</font>
                <label></label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>740</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Movie Poster (ID 20) -->
            <control type="image" id="20">
                <left>30</left>
                <top>82</top>
                <width>160</width>
                <height>240</height>
                <aspectratio>keep</aspectratio>
                <texture background="true">-</texture>
            </control>

            <!-- Message (ID 2) — "You just watched [CR][B]Title[/B]" -->
            <control type="label" id="2">
                <left>210</left>
                <top>85</top>
                <width>560</width>
                <height>95</height>
                <align>left</align>
                <textcolor>ffFFFFFF</textcolor>
                <font>font13</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Subtitle (ID 4) — "Next in [B]Collection[/B]:[CR]Title" -->
            <control type="label" id="4">
                <left>210</left>
                <top>195</top>
                <width>560</width>
                <height>95</height>
                <align>left</align>
                <textcolor>FFAAAAAA</textcolor>
                <font>font12</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Button Row -->
            <control type="group">
                <left>185</left>
                <top>385</top>
                <width>430</width>
                <height>50</height>

                <!-- Yes/primary Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- No/secondary Button (ID 11) -->
                <control type="button" id="11">
                    <left>230</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>

            <!-- Timer Label (ID 3) — auto-close countdown, below buttons -->
            <control type="label" id="3">
                <left>30</left>
                <top>445</top>
                <width>740</width>
                <height>25</height>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>FF888888</textcolor>
                <font>font10</font>
                <label>-</label>
            </control>
        </control>
    </controls>
</window>
