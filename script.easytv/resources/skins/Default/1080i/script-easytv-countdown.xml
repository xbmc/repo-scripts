<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Countdown Dialog (Playlist Continuation)
    Resolution: 1080i (1920x1080)

    Control IDs:
        1  - Heading label (updated by countdown timer)
        2  - Message label
        10 - "Yes" button (left)
        11 - "No" button (right)
-->
<window>
    <zorder>100000</zorder>
    <defaultcontrol always="true">10</defaultcontrol>
    <animation effect="fade" time="200">WindowOpen</animation>
    <animation effect="fade" time="150">WindowClose</animation>

    <controls>
        <!-- Deep dim overlay for cinematic focus -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">OneBlackPixel.png</texture>
        </control>

        <!-- Dialog Container: 600x250 centered -->
        <control type="group">
            <left>660</left>
            <top>415</top>
            <width>600</width>
            <height>250</height>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>600</width>
                <height>250</height>
                <texture border="12">DialogBackground.png</texture>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>30</top>
                <width>540</width>
                <height>40</height>
                <align>center</align>
                <textcolor>FF50e0c7</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator below heading -->
            <control type="image">
                <left>30</left>
                <top>78</top>
                <width>540</width>
                <height>2</height>
                <texture>AccentLine.png</texture>
            </control>

            <!-- Message Label (ID 2) -->
            <control type="label" id="2">
                <left>30</left>
                <top>88</top>
                <width>540</width>
                <height>70</height>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>FFFFFFFF</textcolor>
                <font>font13</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Button Row -->
            <control type="group">
                <left>100</left>
                <top>170</top>
                <width>400</width>
                <height>50</height>

                <!-- Yes Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>185</width>
                    <height>50</height>
                    <align>center</align>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FF0D1117</focusedcolor>
                    <texturefocus border="24">ButtonFocused.png</texturefocus>
                    <texturenofocus border="24">ButtonUnfocused.png</texturenofocus>
                    <onright>11</onright>
                    <onleft>11</onleft>
                </control>

                <!-- No Button (ID 11) -->
                <control type="button" id="11">
                    <left>215</left>
                    <top>0</top>
                    <width>185</width>
                    <height>50</height>
                    <align>center</align>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FF0D1117</focusedcolor>
                    <texturefocus border="24">ButtonFocused.png</texturefocus>
                    <texturenofocus border="24">ButtonUnfocused.png</texturenofocus>
                    <onright>10</onright>
                    <onleft>10</onleft>
                </control>
            </control>
        </control>
    </controls>
</window>
