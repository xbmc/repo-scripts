<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Confirm Dialog
    Resolution: 1080i (1920x1080)

    Simple yes/no confirmation dialog. Also used as OK-only dialog
    when EasyMovie.SingleButton property is set.

    Window properties:
        EasyMovie.SingleButton - "true" hides No button, auto-centers Yes/OK

    Control IDs:
        1  - Heading label
        2  - Message label (primary)
        10 - Yes/OK button
        11 - No/Cancel button
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">10</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 720x240 centered -->
        <control type="group">
            <left>600</left>
            <top>420</top>
            <width>720</width>
            <height>240</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>724</width>
                <height>244</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>720</width>
                <height>240</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>660</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>660</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Message Label (ID 2) -->
            <control type="label" id="2">
                <left>30</left>
                <top>82</top>
                <width>660</width>
                <height>70</height>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>ffFFFFFF</textcolor>
                <font>font13</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Button Row: centered grouplist auto-positions visible buttons -->
            <control type="grouplist">
                <left>145</left>
                <top>170</top>
                <width>430</width>
                <height>50</height>
                <align>center</align>
                <itemgap>30</itemgap>
                <orientation>horizontal</orientation>

                <!-- Yes/OK Button (ID 10) — always visible -->
                <control type="button" id="10">
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- No/Cancel Button (ID 11) — hidden when SingleButton -->
                <control type="button" id="11">
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <visible>!String.IsEqual(Window.Property(EasyMovie.SingleButton),true)</visible>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
