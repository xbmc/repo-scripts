# empty strings from id 32206 to 32299
# Dialog texts
msgctxt "#32300"
msgid "This will move and rename your image files and cannot be undone. Are you sure you want to do this?"
msgstr "Spowoduje to przeniesienie i zmianę nazw plików graficznych. Tej operacji nie można cofnąć. Czy na pewno chcesz to zrobić?"

msgctxt "#32301"
msgid "Unable to retrieve path to Kodi music artist image storage. Please check Settings > Media > Music and ensure the Artist Information Folder is set."
msgstr "Nie można pobrać ścieżki do magazynu obrazów wykonawców muzycznych Kodi. Sprawdź Ustawienia > Media > Muzyka i upewnij się, że folder z informacjami o wykonawcach jest ustawiony."

msgctxt "#32302"
msgid "Artist Slideshow is already set to use the Kodi artist information folder. Please set to use either addon_data folder or a custom location and try again."
msgstr "Pokaz slajdów wykonawcy jest już skonfigurowany do korzystania z folderu informacji o wykonawcy Kodi. Ustaw korzystanie z folderu addon_data lub innej lokalizacji i spróbuj ponownie."

msgctxt "#32303"
msgid "Moving and renaming images from custom location..."
msgstr "Przenoszenie i zmiana nazw obrazów z niestandardowej lokalizacji..."

msgctxt "#32304"
msgid "Moving and renaming images from addon_data folder..."
msgstr "Przenoszenie i zmiana nazw obrazów z folderu addon_data..."

msgctxt "#32305"
msgid "No artist directories found."
msgstr "Nie znaleziono katalogów wykonawców."

msgctxt "#32306"
msgid "Image move complete. You may now change the Artist Slideshow storage location to Kodi artist information folder."
msgstr "Przenoszenie obrazu zakończone. Możesz teraz zmienić lokalizację przechowywania pokazu slajdów wykonawcy na folder z informacjami o wykonawcy w Kodi."

