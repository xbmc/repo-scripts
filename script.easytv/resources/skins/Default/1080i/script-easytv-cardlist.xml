<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Card List View (skin=0)
    Resolution: 1080i (1920x1080)
    Dialog-style: 1400x800 centered

    Compact card rows with poster, show/episode info, and stats.

    Control IDs:
        655 - Main list container
-->
<window>
    <zorder>1</zorder>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 1400x800 centered -->
        <control type="group">
            <left>260</left>
            <top>140</top>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>1404</width>
                <height>804</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1400</width>
                <height>800</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Content (visible when list is populated) -->
            <control type="group">
                <visible>Control.IsVisible(655)</visible>

                <!-- Heading -->
                <control type="label">
                    <left>30</left>
                    <top>13</top>
                    <width>1340</width>
                    <height>40</height>
                    <font>font14_title</font>
                    <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                    <label>$INFO[Window.Property(EasyTV.AddonName)]</label>
                </control>

                <!-- Accent line separator -->
                <control type="image">
                    <left>30</left>
                    <top>66</top>
                    <width>1340</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
                </control>

                <!-- Info bar -->
                <control type="label">
                    <left>30</left>
                    <top>82</top>
                    <width>1340</width>
                    <height>25</height>
                    <align>center</align>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Property(genre),[, ]]$INFO[Container(655).ListItem.Property(duration),  •  ~,/ep]  •  $ADDON[script.easytv 32223] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numondeck)][/COLOR]  •  $ADDON[script.easytv 32224] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numwatched)][/COLOR]  •  $ADDON[script.easytv 32225] [COLOR $INFO[Window.Property(EasyTV.Accent)]]$INFO[Container(655).ListItem.Property(numskipped)][/COLOR]</label>
                </control>
            </control>

            <!-- Card list -->
            <control type="list" id="655">
                <left>30</left>
                <top>122</top>
                <width>1340</width>
                <height>624</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>655</onleft>
                <onright>655</onright>
                <onup>655</onup>
                <ondown>655</ondown>

                <!-- Unfocused card row -->
                <itemlayout width="1340" height="78">
                    <!-- Subtle row background -->
                    <control type="image">
                        <left>0</left>
                        <top>2</top>
                        <width>1340</width>
                        <height>74</height>
                        <texture colordiffuse="0cffffff">common/white.png</texture>
                    </control>

                    <!-- Poster thumbnail -->
                    <control type="image">
                        <left>10</left>
                        <top>4</top>
                        <width>40</width>
                        <height>70</height>
                        <texture background="true">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>

                    <!-- Show title (top left) -->
                    <control type="label">
                        <left>65</left>
                        <top>11</top>
                        <width>890</width>
                        <height>28</height>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>960</left>
                        <top>14</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>

                    <!-- Last watched label + value (top far right) -->
                    <control type="label">
                        <left>1000</left>
                        <top>11</top>
                        <width>330</width>
                        <height>28</height>
                        <align>right</align>
                        <font>font10</font>
                        <textcolor>FF888888</textcolor>
                        <label>[COLOR FF666666]$ADDON[script.easytv 32065][/COLOR]  $INFO[ListItem.Property(lastwatched)]</label>
                    </control>

                    <!-- Episode number + title (bottom left) -->
                    <control type="label">
                        <left>65</left>
                        <top>42</top>
                        <width>890</width>
                        <height>26</height>
                        <font>font10</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <label>[COLOR FF888888]$INFO[ListItem.Property(episodeno)][/COLOR]  $INFO[ListItem.Label2]</label>
                    </control>

                    <!-- Progress label + value (bottom right) -->
                    <control type="label">
                        <left>1000</left>
                        <top>42</top>
                        <width>330</width>
                        <height>26</height>
                        <align>right</align>
                        <font>font10</font>
                        <textcolor>FF888888</textcolor>
                        <label>[COLOR FF666666]$ADDON[script.easytv 32222][/COLOR]  $INFO[ListItem.Property(percentplayed)]</label>
                    </control>
                </itemlayout>

                <!-- Focused card row -->
                <focusedlayout width="1340" height="78">
                    <!-- Accent background -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>1340</width>
                        <height>78</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentBG)]">common/white.png</texture>
                    </control>

                    <!-- Poster thumbnail -->
                    <control type="image">
                        <left>10</left>
                        <top>4</top>
                        <width>40</width>
                        <height>70</height>
                        <texture background="true">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>

                    <!-- Show title (top left, accent color) -->
                    <control type="label">
                        <left>65</left>
                        <top>11</top>
                        <width>890</width>
                        <height>28</height>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Multiselect checkmark -->
                    <control type="image">
                        <left>960</left>
                        <top>14</top>
                        <width>20</width>
                        <height>20</height>
                        <texture>IconWatched.png</texture>
                        <visible>ListItem.IsSelected</visible>
                    </control>

                    <!-- Last watched label + value (top far right) -->
                    <control type="label">
                        <left>1000</left>
                        <top>11</top>
                        <width>330</width>
                        <height>28</height>
                        <align>right</align>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>[COLOR FFCCCCCC]$ADDON[script.easytv 32065][/COLOR]  $INFO[ListItem.Property(lastwatched)]</label>
                    </control>

                    <!-- Episode number + title (bottom left) -->
                    <control type="label">
                        <left>65</left>
                        <top>42</top>
                        <width>890</width>
                        <height>26</height>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>[COLOR FFCCCCCC]$INFO[ListItem.Property(episodeno)][/COLOR]  $INFO[ListItem.Label2]</label>
                    </control>

                    <!-- Progress label + value (bottom right) -->
                    <control type="label">
                        <left>1000</left>
                        <top>42</top>
                        <width>330</width>
                        <height>26</height>
                        <align>right</align>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>[COLOR FFCCCCCC]$ADDON[script.easytv 32222][/COLOR]  $INFO[ListItem.Property(percentplayed)]</label>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
