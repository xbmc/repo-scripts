<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Countdown Dialog (Playlist Continuation)
    Resolution: 1080i (1920x1080)

    Control IDs:
        1  - Heading label (static, addon/clone name)
        2  - Message label (primary)
        3  - Timer label (auto-close countdown, below buttons)
        4  - Subtitle label (secondary, smaller + dimmer)
        10 - "Yes" button (left)
        11 - "No" button (right)
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">10</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 720x310 centered -->
        <control type="group">
            <left>600</left>
            <top>385</top>
            <width>720</width>
            <height>310</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>724</width>
                <height>314</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>720</width>
                <height>310</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>660</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>660</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Message Label (ID 2) — primary -->
            <control type="label" id="2">
                <left>30</left>
                <top>82</top>
                <width>660</width>
                <height>80</height>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>ffFFFFFF</textcolor>
                <font>font13</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Subtitle Label (ID 4) — secondary, smaller + dimmer -->
            <control type="label" id="4">
                <left>30</left>
                <top>162</top>
                <width>660</width>
                <height>25</height>
                <align>center</align>
                <font>font10</font>
                <textcolor>FFAAAAAA</textcolor>
                <label>-</label>
            </control>

            <!-- Button Row -->
            <control type="group">
                <left>145</left>
                <top>190</top>
                <width>430</width>
                <height>50</height>

                <!-- Yes Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- No Button (ID 11) -->
                <control type="button" id="11">
                    <left>230</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>

            <!-- Timer Label (ID 3) — auto-close countdown -->
            <control type="label" id="3">
                <left>30</left>
                <top>255</top>
                <width>660</width>
                <height>30</height>
                <align>center</align>
                <font>font10</font>
                <textcolor>FFAAAAAA</textcolor>
                <label>-</label>
            </control>
        </control>
    </controls>
</window>
