<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Posters View
    Resolution: 1080i (1920x1080)

    Layout: Left info panel (fanart, title, metadata, plot, buttons) + Right poster grid
    Based on EasyTV Posters View structure — no titles in grid, info panel only.

    Control IDs:
        655 - Main poster panel container
        10  - Surprise Me button
        11  - Re-roll button
-->
<window>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Full screen background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D1117">common/white.png</texture>
        </control>

        <!-- Main content group -->
        <control type="group">
            <visible>Control.IsVisible(655)</visible>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Addon name heading -->
            <control type="label">
                <left>40</left>
                <top>15</top>
                <width>1140</width>
                <height>40</height>
                <font>font14_title</font>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <label>$INFO[Window.Property(EasyMovie.AddonName)]</label>
            </control>

            <!-- Movie count -->
            <control type="label">
                <left>40</left>
                <top>20</top>
                <width>1840</width>
                <height>30</height>
                <align>right</align>
                <font>font10</font>
                <textcolor>FF888888</textcolor>
                <label>$INFO[Container(655).CurrentItem] / $INFO[Container(655).NumItems]</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>40</left>
                <top>60</top>
                <width>1840</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- ==================== LEFT SIDE: INFO PANEL ==================== -->
            <control type="group">
                <left>40</left>
                <top>72</top>
                <width>660</width>
                <height>960</height>

                <!-- Fanart preview -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>620</width>
                    <height>349</height>
                    <texture background="true" fallback="">$INFO[Container(655).ListItem.Art(fanart)]</texture>
                    <aspectratio aligny="top">scale</aspectratio>
                </control>

                <!-- Separator line -->
                <control type="image">
                    <left>0</left>
                    <top>357</top>
                    <width>620</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                </control>

                <!-- Movie Title -->
                <control type="label">
                    <left>0</left>
                    <top>369</top>
                    <width>620</width>
                    <height>45</height>
                    <font>font13</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Label]</label>
                </control>

                <!-- Year · MPAA · Rating · Runtime (when MPAA present) -->
                <control type="label">
                    <left>0</left>
                    <top>419</top>
                    <width>620</width>
                    <height>30</height>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  $INFO[Container(655).ListItem.Mpaa]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Year · Rating · Runtime (when no MPAA) -->
                <control type="label">
                    <left>0</left>
                    <top>419</top>
                    <width>620</width>
                    <height>30</height>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Genre -->
                <control type="label">
                    <left>0</left>
                    <top>454</top>
                    <width>620</width>
                    <height>25</height>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Genre]</label>
                </control>

                <!-- Set info -->
                <control type="label">
                    <left>0</left>
                    <top>484</top>
                    <width>620</width>
                    <height>25</height>
                    <font>font10</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Property(set_name)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Separator: after genre when NO collection -->
                <control type="image">
                    <left>0</left>
                    <top>490</top>
                    <width>620</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                    <visible>String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Separator: after set info when collection present -->
                <control type="image">
                    <left>0</left>
                    <top>519</top>
                    <width>620</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Plot: positioned after separator (no collection) -->
                <control type="textbox">
                    <left>0</left>
                    <top>502</top>
                    <width>620</width>
                    <height>395</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                    <visible>String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Plot: positioned after separator (with collection) -->
                <control type="textbox">
                    <left>0</left>
                    <top>531</top>
                    <width>620</width>
                    <height>370</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Buttons -->
                <control type="group">
                    <left>0</left>
                    <top>910</top>
                    <width>620</width>
                    <height>50</height>

                    <control type="button" id="10">
                        <left>0</left>
                        <top>0</top>
                        <width>200</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textoffsetx>10</textoffsetx>
                        <textcolor>FFFFFFFF</textcolor>
                        <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                        <label>$ADDON[script.easymovie 32310]</label>
                        <onup>655</onup>
                        <onright>11</onright>
                        <onleft>11</onleft>
                        <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                        <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                    </control>

                    <control type="button" id="11">
                        <left>230</left>
                        <top>0</top>
                        <width>200</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textoffsetx>10</textoffsetx>
                        <textcolor>FFFFFFFF</textcolor>
                        <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                        <label>$ADDON[script.easymovie 32311]</label>
                        <onup>655</onup>
                        <onright>10</onright>
                        <onleft>10</onleft>
                        <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                        <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                    </control>
                </control>
            </control>

            <!-- ==================== RIGHT SIDE: POSTER GRID ==================== -->
            <control type="panel" id="655">
                <left>720</left>
                <top>72</top>
                <width>1160</width>
                <height>975</height>
                <orientation>vertical</orientation>
                <onleft>10</onleft>
                <onright>655</onright>
                <onup>655</onup>
                <ondown>655</ondown>
                <preloaditems>6</preloaditems>
                <scrolltime tween="sine" easing="out">200</scrolltime>

                <!-- Unfocused poster item -->
                <itemlayout width="220" height="360">
                    <!-- Poster image -->
                    <control type="image">
                        <left>15</left>
                        <top>20</top>
                        <width>190</width>
                        <height>285</height>
                        <texture background="true">$INFO[ListItem.Art(poster)]</texture>
                        <aspectratio aligny="top">scale</aspectratio>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>19</left>
                        <top>24</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>177</left>
                        <top>24</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>
                </itemlayout>

                <!-- Focused poster item -->
                <focusedlayout width="220" height="360">
                    <!-- Accent border -->
                    <control type="image">
                        <left>12</left>
                        <top>17</top>
                        <width>196</width>
                        <height>291</height>
                        <texture border="3" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white.png</texture>
                    </control>

                    <!-- Poster image -->
                    <control type="image">
                        <left>15</left>
                        <top>20</top>
                        <width>190</width>
                        <height>285</height>
                        <texture background="true">$INFO[ListItem.Art(poster)]</texture>
                        <aspectratio aligny="top">scale</aspectratio>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>19</left>
                        <top>24</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>177</left>
                        <top>24</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
