<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Next Episode Dialog
    Resolution: 1080i (1920x1080)

    Control IDs:
        1  - Heading label (updated by countdown timer)
        2  - Message label
        10 - "Yes" button (left)
        11 - "No" button (right)
        20 - Show poster image
-->
<window>
    <zorder>100000</zorder>
    <defaultcontrol always="true">10</defaultcontrol>
    <animation effect="fade" time="200">WindowOpen</animation>
    <animation effect="fade" time="150">WindowClose</animation>

    <controls>
        <!-- Deep dim overlay for cinematic focus -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">OneBlackPixel.png</texture>
        </control>

        <!-- Dialog Container: 800x380 centered -->
        <control type="group">
            <left>560</left>
            <top>350</top>
            <width>800</width>
            <height>380</height>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>800</width>
                <height>380</height>
                <texture border="12">DialogBackground.png</texture>
            </control>

            <!-- Show Poster (ID 20): 150x225 (2:3 ratio) -->
            <control type="image" id="20">
                <left>30</left>
                <top>30</top>
                <width>150</width>
                <height>225</height>
                <aspectratio>keep</aspectratio>
                <texture>-</texture>
            </control>

            <!-- Heading Label (ID 1) — right of poster -->
            <control type="label" id="1">
                <left>210</left>
                <top>30</top>
                <width>560</width>
                <height>40</height>
                <align>center</align>
                <textcolor>FF50e0c7</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator below heading -->
            <control type="image">
                <left>210</left>
                <top>78</top>
                <width>560</width>
                <height>2</height>
                <texture>AccentLine.png</texture>
            </control>

            <!-- Message Label (ID 2) — right of poster -->
            <control type="label" id="2">
                <left>210</left>
                <top>90</top>
                <width>560</width>
                <height>165</height>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>FFFFFFFF</textcolor>
                <font>font13</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Button Row — full width below poster area -->
            <control type="group">
                <left>150</left>
                <top>295</top>
                <width>500</width>
                <height>50</height>

                <!-- Yes Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>235</width>
                    <height>50</height>
                    <align>center</align>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FF0D1117</focusedcolor>
                    <texturefocus border="24">ButtonFocused.png</texturefocus>
                    <texturenofocus border="24">ButtonUnfocused.png</texturenofocus>
                    <onright>11</onright>
                    <onleft>11</onleft>
                </control>

                <!-- No Button (ID 11) -->
                <control type="button" id="11">
                    <left>265</left>
                    <top>0</top>
                    <width>235</width>
                    <height>50</height>
                    <align>center</align>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FF0D1117</focusedcolor>
                    <texturefocus border="24">ButtonFocused.png</texturefocus>
                    <texturenofocus border="24">ButtonUnfocused.png</texturenofocus>
                    <onright>10</onright>
                    <onleft>10</onleft>
                </control>
            </control>
        </control>
    </controls>
</window>
